# ══════════════════════════════════════════════════
# VA/PT Platform — Environment Configuration
# cp .env.example .env → 填入nessus的key
# ══════════════════════════════════════════════════


# ─── Nessus / Tenable ────────────────────────────
# 目前使用中

NESSUS_HOST=127.0.0.1 # nessus_server ip 
NESSUS_PORT=8834

# API Keys
NESSUS_ACCESS_KEY=
NESSUS_SECRET_KEY=


# ─── Burp Suite Enterprise ───────────────────────
# Web Application 掃描
# API 文件: https://portswigger.net/burp/documentation/enterprise/api

BURP_URL=https://burp_server:port
BURP_API_KEY=


# ─── Acunetix ───────────────────────────────────
# Web 弱掃
# API 文件: https://www.acunetix.com/resources/documentation/

# ACUNETIX_URL=https://acunetix-server:3443
# ACUNETIX_API_KEY=


# ─── ThreatSonar (TeamT5) ───────────────────────
# APT 威脅偵測
# 需跟 TeamT5 取得 API 文件

# THREATSONAR_URL=https://threatsonar-server
# THREATSONAR_API_KEY=



# ─── Qualys ─────────────────────────────────────
# 企業級弱掃

# QUALYS_URL=https://qualysapi.qualys.com
# QUALYS_USERNAME=
# QUALYS_PASSWORD=


# ─── 平台設定 ────────────────────────────────────

# API_SECRET_KEY=your-jwt-secret-here
# DATABASE_URL=postgresql://user:pass@localhost:5432/easm
# REDIS_URL=redis://localhost:6379/0